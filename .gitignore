# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local session memory
/memory/

# local reference files (code snippets, ingestion material)
/reference/

# local tools/scripts
/tools/

# logs
/logs/

# test data
/json/

# nginx (generated from example)
/nginx/4chmg2.conf

# docs/superpowers (development tooling)
/docs/superpowers/
