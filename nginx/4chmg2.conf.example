# 4CHMG2 nginx reverse proxy configuration
#
# This config starts as HTTP-only. certbot --nginx will automatically:
#   - Add the HTTPS server block with SSL certificates
#   - Add HTTP-to-HTTPS redirect
#   - Configure SSL parameters
#
# Setup:
#   1. Copy this file:  sudo cp nginx/4chmg2.conf.example /etc/nginx/sites-available/4chmg2
#   2. Edit the copy:   Replace DOMAIN_PLACEHOLDER with your domain
#                        Replace PORT_PLACEHOLDER with your port (default: 3000)
#   3. Enable:          sudo ln -s /etc/nginx/sites-available/4chmg2 /etc/nginx/sites-enabled/
#   4. Remove default:  sudo rm /etc/nginx/sites-enabled/default
#   5. Test:            sudo nginx -t
#   6. Reload:          sudo systemctl reload nginx
#   7. Get SSL cert:    sudo certbot --nginx -d DOMAIN_PLACEHOLDER
#
# The install.sh script does all of this automatically.

# Rate limiting zone — 10 requests/sec per IP with burst
limit_req_zone $binary_remote_addr zone=app:10m rate=10r/s;

# Upstream — Next.js server
upstream 4chmg2_backend {
    server 127.0.0.1:PORT_PLACEHOLDER;
    keepalive 32;
}

# HTTP server — certbot will add HTTPS and redirect automatically
server {
    listen 80;
    listen [::]:80;
    server_name DOMAIN_PLACEHOLDER;

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Gzip
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level 6;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml image/svg+xml;

    # Max upload size (for any future features)
    client_max_body_size 20m;

    # Proxy to Next.js
    location / {
        limit_req zone=app burst=20 nodelay;

        proxy_pass http://4chmg2_backend;
        proxy_http_version 1.1;

        # WebSocket support (for Next.js HMR in dev, and future features)
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        # Pass real client info
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Timeouts — media proxy can be slow (FlareSolverr)
        proxy_connect_timeout 60s;
        proxy_send_timeout 120s;
        proxy_read_timeout 120s;

        # Buffering for large media responses
        proxy_buffering on;
        proxy_buffer_size 16k;
        proxy_buffers 8 32k;
        proxy_busy_buffers_size 64k;
    }

    # Cache Next.js static assets aggressively
    location /_next/static/ {
        proxy_pass http://4chmg2_backend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        expires 365d;
        add_header Cache-Control "public, immutable";
    }
}
