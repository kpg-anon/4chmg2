# =============================================================================
# 4CHMG2 Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to git. It contains instance-specific secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain & SSL
# -----------------------------------------------------------------------------
# Your public domain (no protocol, no trailing slash)
DOMAIN=example.com

# Email for Let's Encrypt SSL certificate registration
SSL_EMAIL=you@example.com

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Port the Next.js server listens on (nginx proxies to this)
PORT=3000

# Bind address (127.0.0.1 = local only, 0.0.0.0 = all interfaces)
# Use 127.0.0.1 when behind nginx (recommended)
HOST=127.0.0.1

# -----------------------------------------------------------------------------
# FlareSolverr
# -----------------------------------------------------------------------------
# FlareSolverr endpoint for Cloudflare bypass (easychan boards)
# Default Docker port is 8191. Change if you use a custom port.
FLARESOLVERR_URL=http://127.0.0.1:8191/v1

# -----------------------------------------------------------------------------
# Build
# -----------------------------------------------------------------------------
# Max threads for the Rust-based SWC compiler during `next build`.
# Lower this on shared/low-resource servers to avoid hitting ulimits.
# On a dedicated VPS with 2-4 cores, you can leave this unset or set to 4.
# RAYON_NUM_THREADS=4

# -----------------------------------------------------------------------------
# Development (optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed dev origins for Next.js hot reload
# Only needed during development, not production
# ALLOWED_DEV_ORIGINS=dev.example.com
